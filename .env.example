# Social Media Archiver - Environment Variables Example
# Copy this to .env and fill in your values

# Nitter instance to use for scraping (optional, can also be in config.json)
# NITTER_INSTANCE=https://nitter.net

# Cloud storage configuration (for Phase 2 features)
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_S3_BUCKET=your_bucket

# GCS (Google Cloud Storage)
# GCS_PROJECT_ID=your_project
# GCS_BUCKET=your_bucket
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# Azure
# AZURE_STORAGE_ACCOUNT_NAME=your_account
# AZURE_STORAGE_ACCOUNT_KEY=your_key
# AZURE_CONTAINER_NAME=your_container

# Mirror posting credentials (for Phase 3 features)
# MASTODON_INSTANCE=https://mastodon.social
# MASTODON_ACCESS_TOKEN=your_token

# Twitter API (for future API-based scraping)
# TWITTER_BEARER_TOKEN=your_token
# TWITTER_API_KEY=your_key
# TWITTER_API_SECRET=your_secret
